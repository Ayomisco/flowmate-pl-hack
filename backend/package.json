{
  "name": "flowmate-backend",
  "version": "0.1.0",
  "description": "FlowMate: Autonomous Financial Operating System",
  "main": "dist/src/app.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/src/app.js",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "ts-node prisma/seed.ts",
    "db:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test": "vitest"
  },
  "keywords": ["flow", "blockchain", "ai", "finance", "autonomous"],
  "author": "FlowMate Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@onflow/fcl": "^1.4.0",
    "@onflow/types": "^1.4.0",
    "@prisma/client": "^5.8.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "bull": "^4.11.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "groq-sdk": "^0.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.1.2",
    "magic-sdk": "^24.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "redis": "^4.6.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/passport-jwt": "^3.0.13",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "prisma": "^5.8.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  }
}
