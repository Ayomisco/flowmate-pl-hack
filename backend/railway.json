{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "context": ".",
    "dockerfile": "Dockerfile"
  },
  "deploy": {
    "startCommand": "sh -c 'npm run db:migrate:deploy && node dist/src/server.js'",
    "restartPolicy": "always",
    "numReplicas": 1
  }
}
