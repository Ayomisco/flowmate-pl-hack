// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model
model User {
  id                String      @id @default(cuid())
  email             String      @unique
  passwordHash      String
  flowAddress       String?     @unique
  magicUserId       String?     @unique
  autonomyMode      String      @default("assist") // manual | assist | autopilot
  dailyLimit        Decimal     @default(50000)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  rules             Rule[]
  transactions      Transaction[]
  vaults            Vault[]
  goals             Goal[]
  notifications     Notification[]
  chatMessages      ChatMessage[]

  @@index([email])
  @@index([flowAddress])
}

// Financial rules
model Rule {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  type              String      // save | send | receive | swap | stake | dca | bill
  status            String      @default("active") // active | paused | completed
  config            Json        // Flexible JSON config

  nextExecution     DateTime?
  lastExecution     DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  transactions      Transaction[]
  scheduledTxs      ScheduledTransaction[]

  @@index([userId])
  @@index([status])
  @@index([nextExecution])
}

// Scheduled transactions (Flow Forte)
model ScheduledTransaction {
  id                String      @id @default(cuid())
  ruleId            String
  rule              Rule        @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  scheduleId        String      @unique // Generated by Flow Forte
  frequency         String      // daily | weekly | monthly
  dayOfWeek         Int?        // 0-6 for weekly
  time              String?     // "09:00"

  status            String      @default("active") // active | paused | completed
  nextExecution     DateTime?
  lastExecution     DateTime?
  executionCount    Int         @default(0)

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([ruleId])
  @@index([status])
  @@index([nextExecution])
}

// Transactions (on-chain history)
model Transaction {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  ruleId            String?
  rule              Rule?       @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  txHash            String      @unique
  type              String      // save | send | receive | swap | stake
  fromAddress       String?
  toAddress         String?
  amount            Decimal
  token             String      @default("FLOW")
  status            String      @default("pending") // pending | confirmed | failed

  explorerUrl       String?
  metadata          Json?       // Additional data

  createdAt         DateTime    @default(now())
  confirmedAt       DateTime?

  @@index([userId])
  @@index([txHash])
  @@index([status])
  @@index([createdAt])
}

// Vaults
model Vault {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  type              String      // available | savings | emergency | staking
  balance           Decimal     @default(0)
  lockedUntil       DateTime?

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@unique([userId, type])
  @@index([userId])
  @@index([type])
}

// Savings goals
model Goal {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  name              String
  targetAmount      Decimal
  currentAmount     Decimal     @default(0)
  deadline          DateTime
  status            String      @default("active")

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([userId])
  @@index([status])
}

// Chat messages
model ChatMessage {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  role              String      // user | agent
  content           String      @db.Text

  parsedIntent      Json?       // { action, amount, recipient, etc }
  confidenceScore   Decimal?    // 0-1 for intent confidence

  createdAt         DateTime    @default(now())

  @@index([userId])
  @@index([createdAt])
}

// Notifications
model Notification {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  type              String      // action_executed | payment_sent | goal_progress | alert
  title             String
  body              String      @db.Text

  read              Boolean     @default(false)
  metadata          Json?

  createdAt         DateTime    @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}
