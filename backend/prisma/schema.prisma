// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum RuleType {
  save
  send
  receive
  swap
  stake
  dca
  bill
}

enum RuleStatus {
  active
  paused
  completed
}

enum VaultType {
  available
  savings
  emergency
  staking
}

enum TransactionStatus {
  pending
  confirmed
  failed
}

enum TransactionType {
  send
  receive
  transfer
  swap
  stake
}

enum AutonomyMode {
  manual
  assist
  autopilot
}

enum NotificationType {
  action_executed
  payment_sent
  goal_progress
  alert
}

// User
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?
  flowAddress   String   @unique
  magicUserId   String?  @unique
  autonomyMode  AutonomyMode @default(manual)
  dailyLimit    Float    @default(10000)
  dailyUsed     Float    @default(0)
  dailyResetAt  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  rules              Rule[]
  vaults             Vault[]
  transactions       Transaction[]
  goals              Goal[]
  chatMessages       ChatMessage[]
  notifications      Notification[]

  @@index([email])
  @@index([flowAddress])
}

// Financial Rule
model Rule {
  id             String   @id @default(cuid())
  userId         String
  type           RuleType
  status         RuleStatus @default(active)
  name           String
  description    String?
  config         Json
  nextExecution  DateTime?
  lastExecution  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  schedules      ScheduledTransaction[]

  @@index([userId])
  @@index([status])
  @@index([type])
}

// Scheduled Transaction (Flow Forte Integration)
model ScheduledTransaction {
  id             String   @id @default(cuid())
  userId         String
  ruleId         String
  scheduleId     String   @unique// On-chain schedule ID
  frequency      String   // daily, weekly, monthly, custom
  dayOfWeek      Int?     // 0-6 for weekly
  time           String?  // HH:mm format
  status         RuleStatus @default(active)
  nextExecution  DateTime
  executionCount Int      @default(0)
  lastExecution  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  rule           Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([status])
  @@index([nextExecution])
}

// Vault (Multi-vault system)
model Vault {
  id             String   @id @default(cuid())
  userId         String
  type           VaultType
  balance        Float    @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
}

// Goal
model Goal {
  id             String   @id @default(cuid())
  userId         String
  name           String
  targetAmount   Float
  currentAmount  Float    @default(0)
  deadline       DateTime
  status         RuleStatus @default(active)
  category       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// Transaction (Blockchain Audit Trail)
model Transaction {
  id             String   @id @default(cuid())
  userId         String
  ruleId         String?
  txHash         String   @unique
  type           TransactionType
  fromAddress    String
  toAddress      String
  amount         Float
  token          String   @default("FLOW")
  status         TransactionStatus @default(pending)
  estimatedCost  Float    @default(0)
  actualCost     Float?
  metadata       Json?
  explorerUrl    String?
  confirmedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rule           Rule?    @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([txHash])
  @@index([createdAt])
}

// Chat Message (AI Conversation History)
model ChatMessage {
  id             String   @id @default(cuid())
  userId         String
  role           String   // user | agent
  content        String   @db.Text
  parsedIntent   Json?
  confidenceScore Float?
  createdAt      DateTime @default(now())

  // Relations
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// Notification
model Notification {
  id             String   @id @default(cuid())
  userId         String
  type           NotificationType
  title          String
  body           String   @db.Text
  read           Boolean  @default(false)
  metadata       Json?
  createdAt      DateTime @default(now())
  readAt         DateTime?

  // Relations
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

// Whitelisted Recipient (Permission Boundary)
model WhitelistedRecipient {
  id             String   @id @default(cuid())
  userId         String
  recipientAddr  String
  alias          String?
  addedAt        DateTime @default(now())

  @@unique([userId, recipientAddr])
  @@index([userId])
}
