generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  passwordHash      String
  flowAddress       String   @unique
  magicUserId       String   @unique
  autonomyMode      String   @default("manual") // manual | assist | autopilot
  dailyLimit        Float    @default(10000)
  dailySpent        Float    @default(0)
  dailyResetTime    DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  rules             Rule[]
  transactions      Transaction[]
  vaults            Vault[]
  goals             Goal[]
  chatMessages      ChatMessage[]
  notifications     Notification[]
  whitelistedRecipients WhitelistedRecipient[]
}

model Rule {
  id                String   @id @default(cuid())
  userId            String
  type              String   // save | send | receive | swap | stake | dca | bill
  status            String   @default("active") // active | paused | completed
  config            Json     // Dynamic config based on type
  nextExecution     DateTime?
  lastExecution     DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledTransaction ScheduledTransaction?
  transactions      Transaction[]

  @@index([userId])
  @@index([type])
}

model ScheduledTransaction {
  id                String   @id @default(cuid())
  ruleId            String   @unique
  scheduleId        String   @unique
  frequency         String   // daily | weekly | monthly | biweekly
  dayOfWeek         Int?     // 0-6 for weekly
  time              String?  // HH:mm format
  status            String   @default("active")
  nextExecution     DateTime
  executionCount    Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  rule              Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  executionRecords  ExecutionRecord[]

  @@index([scheduleId])
}

model ExecutionRecord {
  id                    String   @id @default(cuid())
  scheduledTransactionId String
  timestamp             DateTime @default(now())
  success               Boolean
  message               String?
  txHash                String?

  scheduledTransaction  ScheduledTransaction @relation(fields: [scheduledTransactionId], references: [id], onDelete: Cascade)

  @@index([scheduledTransactionId])
}

model Transaction {
  id                String   @id @default(cuid())
  userId            String
  ruleId            String?
  txHash            String   @unique
  type              String   // send | receive | swap | stake | dca | bill
  fromAddress       String
  toAddress         String
  amount            Float
  token             String   @default("FLOW")
  status            String   @default("pending") // pending | confirmed | failed
  explorerUrl       String?
  metadata          Json?
  confirmedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rule              Rule?    @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([txHash])
}

model Vault {
  id                String   @id @default(cuid())
  userId            String
  type              String   // available | savings | emergency | staking
  balance           Float    @default(0)
  lockedUntil       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
}

model Goal {
  id                String   @id @default(cuid())
  userId            String
  name              String
  targetAmount      Float
  currentAmount     Float    @default(0)
  deadline          DateTime
  status            String   @default("active") // active | achieved | expired
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ChatMessage {
  id                String   @id @default(cuid())
  userId            String
  role              String   // user | agent
  content           String   @db.Text
  parsedIntent      Json?    // Structured intent parsed by AI
  confidenceScore   Float?
  createdAt         DateTime @default(now())

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id                String   @id @default(cuid())
  userId            String
  type              String   // action_executed | payment_sent | goal_progress | alert
  title             String
  body              String   @db.Text
  read              Boolean  @default(false)
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

model WhitelistedRecipient {
  id                String   @id @default(cuid())
  userId            String
  address           String
  nickname          String?
  createdAt         DateTime @default(now())

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, address])
  @@index([userId])
}
