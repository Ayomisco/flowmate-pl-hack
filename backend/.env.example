# ==================== SERVER ====================
PORT=3000
NODE_ENV=development
API_BASE_URL=http://localhost:3000

# ==================== DATABASE ====================
# From your NeonDB provider
DATABASE_URL=postgresql://user:password@aws-us-east-1.neon.tech/flowmate?sslmode=require

# ==================== JWT AUTHENTICATION ====================
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRY=7d

# ==================== FLOW BLOCKCHAIN ====================
# Testnet Configuration
FLOW_NETWORK=testnet
FLOW_ACCESS_NODE=https://rest-testnet.onflow.org
FLOW_ACCOUNT_ADDRESS=YOUR_TESTNET_ACCOUNT_ADDRESS
FLOW_ACCOUNT_PRIVATE_KEY=YOUR_TESTNET_PRIVATE_KEY

# Smart Contract Addresses (after deployment)
FLOWMATE_AGENT_CONTRACT=0x01  # Will be your deployed contract address
VAULT_MANAGER_CONTRACT=0x02   # Will be your deployed contract address
SCHEDULED_TRANSACTIONS_CONTRACT=0x03  # Will be your deployed contract address

# ==================== MAGIC LINK AUTH ====================
# Get from your Magic Link dashboard
MAGIC_API_KEY=pk_live_YOUR_MAGIC_API_KEY
MAGIC_SECRET_KEY=YOUR_MAGIC_SECRET_KEY

# ==================== AI CONFIGURATION ====================
# Options: claude | gemini | openai | ollama
AI_PROVIDER=claude

# Claude API
CLAUDE_API_KEY=sk-ant-YOUR_CLAUDE_API_KEY
CLAUDE_MODEL=claude-3-sonnet-20240229

# Gemini API (alternative)
GEMINI_API_KEY=AIza_YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.0-flash

# OpenAI API (alternative)
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4-turbo

# Ollama (local, free alternative)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# ==================== LOGGING ====================
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# ==================== REDIS (Job Queue) ====================
REDIS_URL=redis://localhost:6379

# ==================== FRONTEND ====================
FRONTEND_URL=http://localhost:5173
FRONTEND_PRODUCTION_URL=https://your-frontend-domain.com
