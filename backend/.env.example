# Database
DATABASE_URL=postgresql://user:password@localhost:5432/flowmate

# Server
PORT=3000
NODE_ENV=development
API_BASE_URL=http://localhost:3000

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=7d

# Flow Blockchain
FLOW_NETWORK=testnet
FLOW_ACCESS_NODE=https://rest-testnet.onflow.org
FLOW_ACCOUNT_ADDRESS=0x...
FLOW_ACCOUNT_PRIVATE_KEY=...

# Smart Contracts (after deployment, add these)
FLOWMATE_AGENT_CONTRACT=...
VAULT_MANAGER_CONTRACT=...
SCHEDULED_TRANSACTIONS_CONTRACT=...

# Magic Link (Walletless Auth)
MAGIC_API_KEY=pk_live_...
MAGIC_SECRET_KEY=sk_live_B2FE5D52EA137792

# AI Provider (claude, gemini, openai, ollama, groq, or llama)
AI_PROVIDER=claude

# Claude API
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Gemini API
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-pro

# OpenAI API
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# Groq API
GROQ_API_KEY=gsk_...
GROQ_MODEL=mixtral-8x7b-32768

# Ollama (Local)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Llama (Alternative)
LLAMA_URL=http://localhost:8080
LLAMA_MODEL=llama

# Redis
REDIS_URL=redis://localhost:6379

# Frontend URLs
FRONTEND_URL=http://localhost:5173
FRONTEND_PRODUCTION_URL=https://flowmate.app

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log
