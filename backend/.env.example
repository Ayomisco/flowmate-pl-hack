# ==========================================
# FlowMate Backend Configuration
# For Production on Railway, configure all variables in Railway dashboard
# ==========================================

# DATABASE - PostgreSQL Connection
# Use Railway PostgreSQL addon or Neon DB
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/flowmate?sslmode=require

# SERVER
PORT=3000
NODE_ENV=production
API_BASE_URL=https://your-railway-backend.railway.app

# JWT Authentication Secrets
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-32-character-secret-key-must-be-safe
JWT_EXPIRY=7d

# ==========================================
# FLOW BLOCKCHAIN CONFIGURATION
# ==========================================
FLOW_NETWORK=testnet
FLOW_ACCESS_NODE=https://rest-testnet.onflow.org
FLOW_ACCOUNT_ADDRESS=0xc26f3fa2883a46db
FLOW_ACCOUNT_PRIVATE_KEY=d7115bde5b9dc30973feeefc9dc18ee7923d3667542032cdcf2a789294ac4cbc

# Smart Contract Addresses (deployed on Flow testnet)
FLOWMATE_AGENT_CONTRACT=0xc26f3fa2883a46db
VAULT_MANAGER_CONTRACT=0xc26f3fa2883a46db
SCHEDULED_TRANSACTIONS_CONTRACT=0xc26f3fa2883a46db

# ==========================================
# AUTHENTICATION
# ==========================================
MAGIC_API_KEY=pk_live_685671DCC4E8ABC2
MAGIC_SECRET_KEY=sk_live_B2FE5D52EA137792

# ==========================================
# AI PROVIDER CONFIGURATION
# Recommended: groq (best cost/performance ratio)
# ==========================================
AI_PROVIDER=groq
GROQ_API_KEY=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
GROQ_MODEL=llama-3.1-70b-versatile

# Alternative: Claude (Anthropic)
# CLAUDE_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ==========================================
# REDIS - Job Queue & Caching
# Use Railway Redis addon for production
# Format: redis://:password@host:port
# ==========================================
REDIS_URL=redis://default:password@host:port

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
FRONTEND_URL=http://localhost:5173
FRONTEND_PRODUCTION_URL=https://your-frontend.vercel.app

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=info
LOG_FILE=logs/app.log
