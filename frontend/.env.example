# Frontend Environment Configuration
# For local development, copy to .env.local and update values

# API Configuration
# Local: http://localhost:3000
# Production: your Railway backend domain
VITE_API_URL=http://localhost:3000

# Magic Link Authentication
# Get from: https://dashboard.magic.link
VITE_MAGIC_PUBLISHABLE_KEY=pk_live_685671DCC4E8ABC2

# Logging Level (debug, info, warn, error)
VITE_LOG_LEVEL=debug

# Optional: Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_CRASH_REPORTS=false
